# MyDailyTradingSignals Frontend - Production Environment Template
# Copy this file to .env.production.local and fill in the values
# DO NOT commit the actual .env.production.local file to git

# ═══════════════════════════════════════════════════════════════════════════
# API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Backend API endpoint
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api

# WebSocket endpoint for live data
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com/ws

# ═══════════════════════════════════════════════════════════════════════════
# LOGGING & MONITORING
# ═══════════════════════════════════════════════════════════════════════════

# Log level: error, warn, info, debug
NEXT_PUBLIC_LOG_LEVEL=error

# Enable Sentry error tracking in production
NEXT_PUBLIC_SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_CRASH_REPORTS=true

# ═══════════════════════════════════════════════════════════════════════════
# BUILD CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Build ID for cache busting
BUILD_ID=

# ═══════════════════════════════════════════════════════════════════════════
# PERFORMANCE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# WebSocket reconnect settings
NEXT_PUBLIC_WS_RECONNECT_ENABLED=true
NEXT_PUBLIC_WS_RECONNECT_INTERVAL=5000
NEXT_PUBLIC_WS_MAX_RECONNECT_ATTEMPTS=10

# Data update intervals (milliseconds)
NEXT_PUBLIC_DATA_UPDATE_INTERVAL=500
NEXT_PUBLIC_UI_REFRESH_INTERVAL=250
