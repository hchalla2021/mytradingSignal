# ==============================================================================
# MyDailyTradingSignals Frontend - Environment Variables
# ==============================================================================
# NO HARDCODED VALUES IN CODE - ALL CONFIG HERE ONLY
# Switch between LOCAL and PRODUCTION by commenting/uncommenting sections below
# ==============================================================================

# ==================== ENVIRONMENT DETECTION ====================
# Production domain (used for auto-detection)
NEXT_PUBLIC_PRODUCTION_DOMAIN=mydailytradesignals.com

# ==================== ACTIVE CONFIGURATION ====================
# 🧪 LOCAL DEVELOPMENT (uncomment for local, comment production below)
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/market
# NEXT_PUBLIC_ENVIRONMENT=local

# 🏭 PRODUCTION (currently active)
NEXT_PUBLIC_API_URL=https://mydailytradesignals.com
NEXT_PUBLIC_WS_URL=wss://mydailytradesignals.com/ws/market
NEXT_PUBLIC_ENVIRONMENT=production

# ==================== FALLBACK URLs (legacy support) ====================
# These are used only if main URL not set - keep for compatibility
NEXT_PUBLIC_LOCAL_API_URL=http://localhost:8002
NEXT_PUBLIC_LOCAL_WS_URL=ws://localhost:8002/ws/market
# NEXT_PUBLIC_PRODUCTION_API_URL=https://mydailytradesignals.com
# NEXT_PUBLIC_PRODUCTION_WS_URL=wss://mydailytradesignals.com/ws/market

# ==================== MARKET CONFIGURATION ====================
# Market symbols to track (comma-separated)
NEXT_PUBLIC_MARKET_SYMBOLS=NIFTY,BANKNIFTY,SENSEX

# ==================== PERFORMANCE SETTINGS ====================
# Refresh interval for polling components (milliseconds)
NEXT_PUBLIC_REFRESH_INTERVAL=3000
NEXT_PUBLIC_ADVANCED_REFRESH_INTERVAL=3000
NEXT_PUBLIC_MARKET_REFRESH_INTERVAL=3000

# WebSocket settings (milliseconds) - Ultra-fast for immediate connection
NEXT_PUBLIC_WS_RECONNECT_DELAY=500
NEXT_PUBLIC_WS_PING_INTERVAL=15000

# API request timeout (milliseconds)
NEXT_PUBLIC_API_TIMEOUT=5000

# Data freshness threshold (milliseconds)
NEXT_PUBLIC_DATA_FRESHNESS_MS=60000

# ==================== FEATURES ====================
NEXT_PUBLIC_ENABLE_AI_ANALYSIS=false

# ==================== ADMIN SETTINGS ====================
# 🔐 Admin Restart Button - Secure key for server restart functionality
# Change this to a strong random key in production!
# This key is used to authorize the admin restart button in the header
# Must match the ADMIN_RESTART_KEY in the backend .env file
NEXT_PUBLIC_ADMIN_KEY=Goodb3fb9c9CH1yZ2DNL3A6CaSqy76aRhj6aItShQzY
# Server-side key used by /api/admin/restart route (must match NEXT_PUBLIC_ADMIN_KEY)
ADMIN_RESTART_KEY=Goodb3fb9c9CH1yZ2DNL3A6CaSqy76aRhj6aItShQzY

# ==================== MARKET POSITIONING ====================
# Poll interval for Market Positioning Intelligence section (milliseconds)
NEXT_PUBLIC_POSITIONING_INTERVAL=5000

# ==================== NODE SETTINGS ====================
NODE_OPTIONS=--max-old-space-size=2048
