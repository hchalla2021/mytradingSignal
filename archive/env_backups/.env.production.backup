# ==============================================================================
# MyTradingSignal Backend - Production Environment (Digital Ocean)
# ==============================================================================
# Copy this file to /var/www/mytradingSignal/backend/.env on production server

# ==================== ZERODHA API ====================
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_API_SECRET=your_zerodha_api_secret_here
ZERODHA_ACCESS_TOKEN=will_be_generated_on_login

# ==================== OAUTH & REDIRECT ====================
# PRODUCTION URLs
PRODUCTION_REDIRECT_URL=https://mydailytradesignals.com/api/auth/callback
PRODUCTION_FRONTEND_URL=https://mydailytradesignals.com

# FORCE PRODUCTION MODE
ENVIRONMENT=production

# ==================== JWT ====================
JWT_SECRET=generate_a_strong_random_secret_here_min_32_chars

# ==================== SERVER ====================
HOST=0.0.0.0
PORT=8000
DEBUG=False
CORS_ORIGINS=https://mydailytradesignals.com

# ==================== MARKET HOURS SCHEDULER ====================
# 🔥 CRITICAL: Enable scheduler in production to avoid API calls during market closed
ENABLE_SCHEDULER=true

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379

# ==================== INSTRUMENT TOKENS ====================
NIFTY_TOKEN=256265
BANKNIFTY_TOKEN=260105
SENSEX_TOKEN=265
FINNIFTY_TOKEN=257801
MIDCPNIFTY_TOKEN=288009

# FUTURES TOKENS FOR VOLUME DATA
# Update these monthly when futures contracts expire
NIFTY_FUT_TOKEN=12602626
BANKNIFTY_FUT_TOKEN=12601346
SENSEX_FUT_TOKEN=292786437
