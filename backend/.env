# ==================== MARKET POSITIONING INTELLIGENCE ====================
# Rolling history points for 5-min prediction (30 points × 5s = ~2.5 min window)
POSITIONING_HISTORY_POINTS=30
# Minimum % change to classify direction (avoids noise)
POSITIONING_STRONG_THRESHOLD=70
POSITIONING_BUY_THRESHOLD=55
POSITIONING_OI_CHANGE_MIN_PCT=0.05
POSITIONING_VOL_CHANGE_MIN_PCT=0.03