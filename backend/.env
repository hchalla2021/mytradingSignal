# ==================== JWT ====================
JWT_SECRET=mydailytradingsignals-secret-key-2024

# ==================== ADMIN RESTART ====================
# 🔐 Secure key for admin restart button functionality
# Must match NEXT_PUBLIC_ADMIN_KEY in frontend .env.local
# Used to authorize the /api/admin/restart endpoint
ADMIN_RESTART_KEY=superSecretRestartKey123

# ==================== SERVER ====================
HOST=0.0.0.0
PORT=8000
DEBUG=False

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379

# ==================== MARKET HOURS SCHEDULER ====================
# true = only run during market hours, false = always run
ENABLE_SCHEDULER=true

# ==================== TIMEZONE CONFIGURATION ====================
# 🔥 CRITICAL: Set timezone to IST (Asia/Kolkata) for correct market hours
# If this is wrong, market will show as CLOSED at wrong times
# DO NOT change this to UTC - it will break market timing!
MARKET_TIMEZONE=Asia/Kolkata

# ==================== INSTRUMENT TOKENS ====================
NIFTY_TOKEN=256265
BANKNIFTY_TOKEN=260105
SENSEX_TOKEN=265
FINNIFTY_TOKEN=257801
MIDCPNIFTY_TOKEN=288009

