# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379

# ==================== MARKET HOURS SCHEDULER ====================
# true = only run during market hours, false = always run
ENABLE_SCHEDULER=true

# ==================== TIMEZONE CONFIGURATION ====================
# 🔥 CRITICAL: Set timezone to IST (Asia/Kolkata) for correct market hours
# If this is wrong, market will show as CLOSED at wrong times
# DO NOT change this to UTC - it will break market timing!
MARKET_TIMEZONE=Asia/Kolkata

