# ==================== ZERODHA API ====================
# ⚠️ SENSITIVE: DO NOT COMMIT THESE VALUES TO GIT
# ==================== ZERODHA API ====================
ZERODHA_API_KEY=g5tyrnn1mlckrb6f
ZERODHA_API_SECRET=6cusjkixpyv7pii7c2rtei61ewcoxj3l
ZERODHA_ACCESS_TOKEN=IE3dwjk2S4sZvmDePJF5nEt4qvSRfC1v

# ==================== ACTIVE CONFIGURATION ====================
# 🏭 PRODUCTION (active for live deployment)
REDIRECT_URL=https://mydailytradesignals.com/api/auth/callback
FRONTEND_URL=https://mydailytradesignals.com
CORS_ORIGINS=https://mydailytradesignals.com,http://localhost:3000,http://127.0.0.1:3000

# 🧪 LOCAL DEVELOPMENT (uncomment for local, comment production above)
# REDIRECT_URL=http://localhost:8000/api/auth/callback
# FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# ==================== JWT ====================
# ⚠️ CHANGE THIS to a strong random string (32+ chars) before production!
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_SECRET_32CHARS

# ==================== ADMIN RESTART ====================
# 🔐 Secure key for admin restart button functionality
# Must match NEXT_PUBLIC_ADMIN_KEY in frontend .env.local
# ⚠️ CHANGE THIS to a strong random string before production!
ADMIN_RESTART_KEY=CHANGE_ME_USE_STRONG_RANDOM_KEY

# ==================== SERVER ====================
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379

# ==================== MARKET HOURS SCHEDULER ====================
# true = only run during market hours, false = always run
ENABLE_SCHEDULER=true

# ==================== TIMEZONE CONFIGURATION ====================
# 🔥 CRITICAL: Set timezone to IST (Asia/Kolkata) for correct market hours
# If this is wrong, market will show as CLOSED at wrong times
# DO NOT change this to UTC - it will break market timing!
MARKET_TIMEZONE=Asia/Kolkata

# ==================== INSTRUMENT TOKENS ====================
NIFTY_TOKEN=256265
BANKNIFTY_TOKEN=260105
SENSEX_TOKEN=265
FINNIFTY_TOKEN=257801
MIDCPNIFTY_TOKEN=288009

